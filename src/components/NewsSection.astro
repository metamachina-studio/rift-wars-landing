---
import NewsCard from './NewsCard.astro';
import { articles } from '../lib/news';

const displayArticles = articles.slice(0, 4);
---

<section id="news" class="section-padding section-charcoal section-divide-top relative overflow-hidden">
  <div class="section-bg-img" style="background-image: url('/art/bg/MMGrid8.webp'); opacity: 0.04;"></div>
  <div class="section-container relative z-[2]">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <p class="font-mono text-mm-gold-primary uppercase tracking-[0.3em] text-xs mb-3">// DISPATCHES</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-orbitron text-mm-gold-primary neon-text mb-4 glitch-text" data-text="News & Updates">News & Updates</h2>
      <div class="scan-divider max-w-lg mx-auto mt-6"></div>
    </div>

    <!-- News Grid (4 max, 4-col) -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {displayArticles.map((article, i) => (
        <NewsCard article={article} index={i} />
      ))}
    </div>

    <!-- All News Link -->
    <div class="text-center mt-10 reveal">
      <a href="/news" class="btn-primary text-sm">View Archive</a>
    </div>
  </div>
</section>
