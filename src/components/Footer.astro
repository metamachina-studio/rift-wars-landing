---
const gameUrl = import.meta.env.PUBLIC_GAME_URL || 'https://rift.metamachina.io';
const year = new Date().getFullYear();
---

<footer class="bg-mm-bg border-t border-mm-elevated/30">
  <div class="section-container py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-3 mb-4">
          <img src="/rift-wars-logo-small.webp" alt="Rift Wars" class="h-10" />
          <div>
            <span class="font-orbitron font-bold text-mm-gold-primary text-lg tracking-wider">RIFT WARS</span>
            <p class="font-rajdhani text-mm-text2 text-sm uppercase tracking-wide">A Meta Machina Game</p>
          </div>
        </div>
        <p class="text-mm-text2 text-sm max-w-md leading-relaxed">
          A free-to-play, skill-based tactical card game set in the cyberpunk wasteland of Pangaea III.
          Every card is earnable. Skill wins. No pay-to-win.
        </p>
      </div>

      <!-- Play -->
      <div>
        <h4 class="font-rajdhani font-bold text-sm uppercase tracking-wider text-mm-text mb-4">Play</h4>
        <ul class="space-y-2">
          <li><a href={gameUrl} target="_blank" rel="noopener" class="text-mm-text2 hover:text-mm-gold-primary transition-colors text-sm">Play Rift Wars</a></li>
          <li><a href="#features" class="text-mm-text2 hover:text-mm-gold-primary transition-colors text-sm">Game Features</a></li>
          <li><a href="#cards" class="text-mm-text2 hover:text-mm-gold-primary transition-colors text-sm">Card Gallery</a></li>
          <li><a href="/rankings" class="text-mm-text2 hover:text-mm-gold-primary transition-colors text-sm">Leaderboard</a></li>
        </ul>
      </div>

      <!-- Community -->
      <div>
        <h4 class="font-rajdhani font-bold text-sm uppercase tracking-wider text-mm-text mb-4">Community</h4>
        <ul class="space-y-2">
          <li><a href="https://x.com/MetaMachina_RW" target="_blank" rel="noopener" class="text-mm-text2 hover:text-mm-gold-primary transition-colors text-sm">Rift Wars on X</a></li>
          <li><a href="https://x.com/Meta_Machina" target="_blank" rel="noopener" class="text-mm-text2 hover:text-mm-gold-primary transition-colors text-sm">Meta Machina on X</a></li>
          <li><a href="https://discord.gg/dNcvNkc33C" target="_blank" rel="noopener" class="text-mm-text2 hover:text-mm-gold-primary transition-colors text-sm">Discord</a></li>
          <li><a href="https://x.com/1DigitalC" target="_blank" rel="noopener" class="text-mm-text2 hover:text-mm-gold-primary transition-colors text-sm">Developer (@1DigitalC)</a></li>
          <li><a href="https://github.com/metamachina-studio" target="_blank" rel="noopener" class="text-mm-text2 hover:text-mm-gold-primary transition-colors text-sm">GitHub</a></li>
          <li><a href="https://metamachina.io" target="_blank" rel="noopener" class="text-mm-text2 hover:text-mm-gold-primary transition-colors text-sm">Meta Machina Universe</a></li>
          <li><a href="/about" class="text-mm-text2 hover:text-mm-gold-primary transition-colors text-sm">About the Developer</a></li>
        </ul>
      </div>
    </div>

    <!-- Solo Developer Credit -->
    <div class="scan-divider mt-12 mb-6"></div>
    <div class="dev-credit-block">
      <div class="ai-disclaimer-tag mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Some content created with AI
      </div>
      <p class="text-mm-text2 text-sm max-w-2xl mx-auto leading-relaxed text-center">
        Rift Wars is solo developed by
        <a href="https://x.com/1DigitalC" target="_blank" rel="noopener" class="text-mm-gold-primary hover:text-mm-gold transition-colors font-semibold">@1DigitalC</a>,
        built with heavy use of personal art assets and AI technology.
        Current art is not final and will go through rigorous revamping while keeping the style, flavor, and vibe of the originals.
        Original art will be featured across all aspects of Rift Wars.
      </p>
    </div>

    <!-- Bottom bar -->
    <div class="scan-divider mt-6 mb-6"></div>
    <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-mm-muted text-xs">
      <p>&copy; {year} Meta Machina. All rights reserved.</p>
      <div class="flex items-center gap-6">
        <a href="/privacy" class="hover:text-mm-text2 transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-mm-text2 transition-colors">Terms</a>
        <a href="/beta-disclaimer" class="hover:text-mm-text2 transition-colors">Beta Disclaimer</a>
        <a href="/nft-terms" class="hover:text-mm-text2 transition-colors">NFT Terms</a>
        <a href="/dmca" class="hover:text-mm-text2 transition-colors">DMCA</a>
      </div>
    </div>
  </div>
</footer>
