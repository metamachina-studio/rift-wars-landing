---
const gameUrl = import.meta.env.PUBLIC_GAME_URL || 'https://rift.metamachina.io';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Video Background -->
  <video
    autoplay
    muted
    loop
    playsinline
    class="absolute inset-0 w-full h-full object-cover"
    poster="/rift-wars-logo-dark.webp"
  >
    <source src="/video/arena.mp4" type="video/mp4" />
  </video>

  <!-- Dark Overlay -->
  <div class="absolute inset-0 bg-gradient-to-b from-mm-bg/60 via-mm-bg/70 to-mm-bg z-[1]"></div>

  <!-- Scanlines -->
  <div class="absolute inset-0 scanlines z-[2] pointer-events-none"></div>

  <!-- Ambient Embers -->
  <div id="hero-embers" class="ember-field z-[3]" aria-hidden="true"></div>

  <!-- Content — pt-20 ensures logo clears the fixed nav -->
  <div id="hero-parallax" class="relative z-10 text-center px-6 max-w-4xl mx-auto pt-20">
    <!-- Meta Machina Logo -->
    <img
      src="/MetaMachina.webp"
      alt="Meta Machina"
      class="parallax-layer w-auto h-14 sm:h-[6.3rem] md:h-[9rem] mx-auto mb-4"
      data-depth="0.6"
    />

    <!-- Rift Wars Logo -->
    <img
      src="/RiftWarsLogo.webp"
      alt="RIFT WARS"
      class="parallax-layer w-[22.5rem] sm:w-[23rem] md:w-[34.5rem] h-auto mx-auto mb-12"
      style="filter: drop-shadow(0 0 20px rgba(242,173,35,0.4)) drop-shadow(0 0 60px rgba(242,173,35,0.2));"
      data-depth="1.2"
    />
    <div class="inline-block px-5 py-1 mb-4 bg-[#fbbf24] border-[1.5px] border-[#fbbf24] rounded-sm" style="box-shadow: 0 0 12px rgba(251,191,36,0.5), 0 0 25px rgba(251,191,36,0.2);">
      <span class="font-orbitron text-sm font-bold tracking-[3px] text-black uppercase">Open Beta</span>
    </div>

    <!-- Server Status Banner (hidden by default, shown by JS) -->
    <div id="server-status" class="hidden mb-4">
      <div id="status-online" class="hidden inline-flex items-center gap-2 px-4 py-1.5 rounded-sm border" style="background: rgba(74,222,128,0.1); border-color: rgba(74,222,128,0.3);">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        <span class="font-orbitron text-xs font-bold tracking-[2px] text-green-400 uppercase">Servers Online</span>
      </div>
      <div id="status-maintenance" class="hidden inline-flex items-center gap-2 px-4 py-1.5 rounded-sm border" style="background: rgba(255,160,0,0.15); border-color: rgba(255,160,0,0.4);">
        <span class="w-2 h-2 rounded-full bg-amber-400"></span>
        <span class="font-orbitron text-xs font-bold tracking-[2px] text-amber-400 uppercase">Scheduled Maintenance</span>
        <span id="status-msg" class="font-exo text-xs text-amber-400/70"></span>
      </div>
    </div>

    <p class="split-text font-rajdhani text-xl sm:text-2xl md:text-3xl text-mm-text2 uppercase tracking-widest mb-2">
      Free-to-Play Tactical Card Game
    </p>
    <p class="font-exo text-mm-text/90 text-base sm:text-lg max-w-2xl mx-auto mb-12 leading-relaxed">
      <span class="glow-stat-green text-xl count-up">4276</span> unique cards.
      <span class="glow-stat-green text-xl count-up">16</span> clans.
      <span class="glow-stat-green text-xl count-up">21</span> ability types.
      Strategic <span class="glow-stat-green text-xl">5&times;5</span> board control.
      Every card earnable. Skill wins. No pay-to-win.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
      <a href={gameUrl} target="_blank" rel="noopener" class="btn-primary btn-filled text-base px-10 py-4">
        Play Free
      </a>
      <button id="watch-gameplay-btn" class="btn-primary text-base px-10 py-4 flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
        Watch Gameplay
      </button>
      <a href="#features" class="btn-primary text-base px-10 py-4">
        Learn More
      </a>
    </div>

    <!-- Video Modal -->
    <div id="video-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 backdrop-blur-sm">
      <div class="relative w-full max-w-4xl mx-4">
        <button id="close-video-btn" class="absolute -top-10 right-0 text-white/70 hover:text-white text-2xl font-bold cursor-pointer">&times;</button>
        <video id="gameplay-video" controls class="w-full rounded-lg shadow-2xl" style="box-shadow: 0 0 60px rgba(242,173,35,0.3);">
          <source src="/video/how-to-play.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </div>

  <!-- Scroll Indicator — Gold Chevron Pulse -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 chevron-pulse">
    <span>&#9660;</span>
    <span>&#9660;</span>
    <span>&#9660;</span>
  </div>
</section>

<script>
  const btn = document.getElementById('watch-gameplay-btn');
  const modal = document.getElementById('video-modal');
  const closeBtn = document.getElementById('close-video-btn');
  const video = document.getElementById('gameplay-video') as HTMLVideoElement | null;

  btn?.addEventListener('click', () => {
    if (modal) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }
    video?.play();
  });

  function closeModal() {
    if (modal) {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
    }
    video?.pause();
  }

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Server status check
  const statusContainer = document.getElementById('server-status');
  const statusOnline = document.getElementById('status-online');
  const statusMaintenance = document.getElementById('status-maintenance');
  const statusMsg = document.getElementById('status-msg');

  async function checkServerStatus() {
    try {
      const res = await fetch('https://api.metamachina.io/health', { signal: AbortSignal.timeout(5000) });
      const data = await res.json();
      statusContainer?.classList.remove('hidden');
      if (data.status === 'maintenance') {
        statusOnline?.classList.add('hidden');
        statusMaintenance?.classList.remove('hidden');
        if (statusMsg) statusMsg.textContent = data.maintenance ? `\u2014 ${data.maintenance}` : '';
      } else {
        statusMaintenance?.classList.add('hidden');
        statusOnline?.classList.remove('hidden');
      }
    } catch {
      statusContainer?.classList.remove('hidden');
      statusOnline?.classList.add('hidden');
      statusMaintenance?.classList.remove('hidden');
      if (statusMsg) statusMsg.textContent = "\u2014 We'll be back shortly";
    }
  }

  checkServerStatus();
  setInterval(checkServerStatus, 30_000);

  // ----- Ambient Embers -----
  const emberField = document.getElementById('hero-embers');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (emberField && !prefersReducedMotion) {
    const emberCount = 28;
    for (let i = 0; i < emberCount; i++) {
      const e = document.createElement('span');
      e.className = 'ember';
      const left = Math.random() * 100;
      const size = 1 + Math.random() * 2;
      const duration = 8 + Math.random() * 10;
      const delay = -Math.random() * 18;
      const drift = (Math.random() - 0.5) * 120;
      e.style.left = `${left}%`;
      e.style.width = `${size}px`;
      e.style.height = `${size}px`;
      e.style.animationDuration = `${duration}s`;
      e.style.animationDelay = `${delay}s`;
      e.style.setProperty('--drift', `${drift}px`);
      emberField.appendChild(e);
    }
  }

  // ----- Mouse Parallax on Hero logos -----
  const parallaxRoot = document.getElementById('hero-parallax');
  const layers = parallaxRoot?.querySelectorAll<HTMLElement>('.parallax-layer');
  const heroSection = document.getElementById('hero');
  const isCoarse = window.matchMedia('(hover: none), (pointer: coarse)').matches;

  if (heroSection && layers?.length && !isCoarse && !prefersReducedMotion) {
    let tx = 0;
    let ty = 0;
    let cx = 0;
    let cy = 0;

    heroSection.addEventListener('mousemove', (e) => {
      const rect = heroSection.getBoundingClientRect();
      const mxn = (e.clientX - rect.left) / rect.width - 0.5; // -0.5 .. 0.5
      const myn = (e.clientY - rect.top) / rect.height - 0.5;
      tx = mxn;
      ty = myn;
    });

    heroSection.addEventListener('mouseleave', () => {
      tx = 0;
      ty = 0;
    });

    const loop = () => {
      cx += (tx - cx) * 0.08;
      cy += (ty - cy) * 0.08;
      layers.forEach((layer) => {
        const depth = parseFloat(layer.dataset.depth ?? '1');
        const dx = cx * depth * 18;
        const dy = cy * depth * 12;
        layer.style.transform = `translate3d(${dx}px, ${dy}px, 0)`;
      });
      requestAnimationFrame(loop);
    };
    requestAnimationFrame(loop);
  }
</script>
