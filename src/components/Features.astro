---
const gameUrl = import.meta.env.PUBLIC_GAME_URL || 'https://rift.metamachina.io';
---

<section id="features" class="section-padding section-charcoal section-divide-top relative overflow-hidden">
  <div class="section-bg-img section-bg-drift" style="background-image: url('/art/bg/MMGrid3.webp'); opacity: 0.05;"></div>
  <div class="section-container relative z-[2]">
    <!-- Section Header -->
    <div class="text-center mb-16 reveal">
      <p class="font-mono text-mm-gold-primary uppercase tracking-[0.3em] text-xs mb-3">// SYSTEM BRIEFING</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-orbitron text-mm-gold-primary neon-text mb-4 glitch-text" data-text="Game Features">Game Features</h2>
      <div class="scan-divider max-w-lg mx-auto mt-6"></div>
    </div>

    <!-- Hero Feature — Strategic 5x5 Board -->
    <div class="reveal-scale mb-16">
      <div class="flex flex-col items-center text-center">
        <span class="font-mono text-mm-gold-primary text-xs uppercase tracking-wider data-flicker mb-2">25 TILES &middot; 2 PLAYERS &middot; 1 WINNER</span>
        <h3 class="font-orbitron text-2xl md:text-3xl font-bold text-mm-text mb-4 tracking-wide">Strategic 5&times;5 Board</h3>
        <p class="font-exo text-mm-text2 text-base leading-relaxed max-w-2xl mb-8">
          Place cards on a 5&times;5 grid to seize territory and control rows. Card abilities can flip, destroy, or shield tiles — and your hero's Shinpodo moves can reshape the entire battlefield. Every turn matters.
        </p>

        <!-- Board: P1 | Grid | P2 -->
        <div style="display:flex;align-items:center;gap:1rem;">
          <div class="flex flex-col items-center gap-2">
            <div class="w-10 h-10 md:w-12 md:h-12 border-2 border-mm-neon flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#39ff14" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <span class="font-mono text-mm-neon text-xs font-bold tracking-wider">P1</span>
          </div>

          <div id="battle-grid" class="board-grid">
            {Array.from({ length: 25 }).map((_, i) => (
              <div class="grid-cell" data-cell={i}></div>
            ))}
          </div>

          <div class="flex flex-col items-center gap-2">
            <div class="w-10 h-10 md:w-12 md:h-12 border-2 border-mm-red flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#ff1744" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <span class="font-mono text-mm-red text-xs font-bold tracking-wider">P2</span>
          </div>
        </div>

      </div>
      <div class="scan-divider mt-10"></div>
    </div>

    <!-- 3-Column Row — no boxes, just content -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      <!-- 4,276 Unique Cards -->
      <div class="reveal-left stagger-1 text-center md:text-left">
        <span class="font-orbitron text-5xl font-black text-[#a855f7] countup" data-target="4276" style="text-shadow: 0 0 20px rgba(168,85,247,0.4);">0</span>
        <span class="font-orbitron text-2xl font-black text-[#a855f7]/60">+</span>
        <h3 class="font-orbitron text-lg font-bold text-mm-text mt-2 mb-3 tracking-wide">Unique Cards</h3>
        <p class="font-exo text-mm-text2 text-sm leading-relaxed">16 clans, 21 ability types, 5 rarities. From common frontline units to god-tier reality benders.</p>
      </div>

      <!-- Shinpodo Classes -->
      <div class="reveal-scale stagger-2 text-center md:text-left">
        <div class="flex items-baseline gap-3 justify-center md:justify-start">
          <span class="font-orbitron text-5xl font-black text-mm-gold countup" data-target="4" style="text-shadow: 0 0 20px rgba(251,191,36,0.4);">0</span>
          <span class="font-mono text-mm-gold/60 text-xs uppercase tracking-wider">Classes</span>
        </div>
        <h3 class="font-orbitron text-lg font-bold text-mm-text mt-2 mb-3 tracking-wide">Shinpodo Classes</h3>
        <p class="font-exo text-mm-text2 text-sm leading-relaxed">Kazen (wind), Iwakami (stone), Seika (flame), Mizu (water). Each unlocks hero abilities and passive bonuses.</p>
      </div>

      <!-- Ranked Multiplayer -->
      <div class="reveal-right stagger-3 text-center md:text-left">
        <span class="font-mono text-mm-gold-primary text-xs uppercase tracking-wider data-flicker">ELO RANKED</span>
        <h3 class="font-orbitron text-lg font-bold text-mm-text mt-3 mb-3 tracking-wide">Ranked Multiplayer</h3>
        <p class="font-exo text-mm-text2 text-sm leading-relaxed">Real-time WebSocket matches with ELO ranking. Climb the leaderboard, join clans, challenge friends.</p>
      </div>
    </div>

    <div class="scan-divider mb-16"></div>

    <!-- 2-Column Row — no boxes -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
      <!-- 6-Tier AI -->
      <div class="reveal-left stagger-4">
        <div class="flex items-center gap-4 mb-3">
          <span class="font-orbitron text-5xl font-black text-mm-neon countup" data-target="6" style="text-shadow: 0 0 20px rgba(57,255,20,0.4);">0</span>
          <div>
            <h3 class="font-orbitron text-lg font-bold text-mm-text tracking-wide">AI Difficulty Tiers</h3>
            <p class="font-mono text-mm-neon/60 text-xs uppercase tracking-wider">Recruit &rarr; Nightmare</p>
          </div>
        </div>
        <p class="font-exo text-mm-text2 text-sm leading-relaxed mb-4">Practice against AI from beginner to full minimax with beam pruning. Master your strategy before entering ranked.</p>
        <!-- Animated tier bars -->
        <div class="flex gap-1">
          {['Recruit', 'Soldier', 'Veteran', 'Elite', 'Master', 'Nightmare'].map((tier, i) => (
            <div class="flex-1 flex flex-col items-center gap-1">
              <div class="w-full tier-bar" style={`height: ${8 + i * 6}px; background: rgba(57,255,20,${0.2 + i * 0.15});`}></div>
              <span class="font-mono text-[0.5rem] text-mm-muted hidden md:block">{tier.slice(0,3)}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- No Pay-to-Win -->
      <div class="reveal-right stagger-5">
        <div class="flex items-center gap-4 mb-3">
          <div class="w-12 h-12 flex items-center justify-center border border-mm-neon/30 text-mm-neon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
          </div>
          <div>
            <h3 class="font-orbitron text-lg font-bold text-mm-text tracking-wide">No Pay-to-Win</h3>
            <span class="font-mono text-mm-neon text-xs uppercase tracking-wider data-flicker">100% FREE TO COMPETE</span>
          </div>
        </div>
        <p class="font-exo text-mm-text2 text-sm leading-relaxed">Every single card is earnable through gameplay. Your skill is your only advantage. Free-to-play means free-to-compete.</p>
      </div>
    </div>
  </div>
</section>

<script>
  // Count-up animation for stat numbers
  const countObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0', 10);
        const duration = target > 100 ? 2000 : 800;
        const start = performance.now();

        function step(now: number) {
          const elapsed = now - start;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - (1 - progress) * (1 - progress);
          el.textContent = Math.floor(eased * target).toLocaleString();
          if (progress < 1) requestAnimationFrame(step);
        }

        requestAnimationFrame(step);
        countObserver.unobserve(el);
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('.countup').forEach((el) => countObserver.observe(el));

  // Mock match simulation on the 5x5 grid
  const grid = document.getElementById('battle-grid');
  if (grid) {
    const cells = grid.querySelectorAll('.grid-cell') as NodeListOf<HTMLElement>;

    const moves: [number, 1 | 2][] = [
      [5, 1],  [14, 2],
      [10, 2], [9, 2],
      [0, 1],  [13, 2],
      [20, 1], [18, 2],
      [6, 1],  [12, 2],
      [1, 1],  [15, 2],
      [24, 1], [8, 2],
      [21, 1], [16, 2],
      [3, 1],  [17, 2],
      [11, 1], [19, 2],
      [22, 1], [7, 2],
      [4, 1],  [23, 2],
      [2, 1],
    ];

    let moveIndex = 0;
    let running = false;

    function resetGrid() {
      cells.forEach((cell) => {
        cell.className = 'grid-cell';
      });
      moveIndex = 0;
    }

    function playMove() {
      if (moveIndex >= moves.length) {
        setTimeout(() => {
          resetGrid();
          setTimeout(playMove, 800);
        }, 3000);
        return;
      }

      const [cellIdx, player] = moves[moveIndex];
      const cell = cells[cellIdx];
      cell.className = player === 1 ? 'grid-cell p1' : 'grid-cell p2';

      moveIndex++;
      setTimeout(playMove, 600);
    }

    const gridObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !running) {
          running = true;
          setTimeout(playMove, 500);
        }
      });
    }, { threshold: 0.3 });

    gridObserver.observe(grid);
  }
</script>

<style>
  .tier-bar {
    transition: height 0.6s ease;
  }

  .board-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    grid-template-rows: repeat(5, 1fr);
    width: 14rem;
    height: 14rem;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }
  @media (min-width: 768px) {
    .board-grid {
      width: 18rem;
      height: 18rem;
    }
  }
  .grid-cell {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transition: all 0.3s ease;
  }
  .grid-cell.p1 {
    background: rgba(57, 255, 20, 0.35);
    border-color: rgba(57, 255, 20, 0.5);
    box-shadow: inset 0 0 12px rgba(57, 255, 20, 0.3), 0 0 16px rgba(57, 255, 20, 0.4);
  }
  .grid-cell.p2 {
    background: rgba(255, 23, 68, 0.4);
    border-color: rgba(255, 23, 68, 0.5);
    box-shadow: inset 0 0 12px rgba(255, 23, 68, 0.3), 0 0 16px rgba(255, 23, 68, 0.4);
  }
</style>
