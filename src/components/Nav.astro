---
const gameUrl = import.meta.env.PUBLIC_GAME_URL || 'https://rift.metamachina.io';

const navLinks = [
  { label: 'Features', href: '/#features', section: 'features' },
  { label: 'Cards', href: '/#cards', section: 'cards' },
  { label: 'News', href: '/#news', section: 'news' },
  { label: 'Rankings', href: '/rankings', section: null },
  { label: 'Shop', href: '/#shop', section: 'shop' },
  { label: 'AI Agents', href: '/#agents', section: 'agents' },
];
---

<header id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 overflow-x-clip">
  <div class="max-w-[1400px] mx-auto px-6 h-16 flex items-center justify-between relative">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 z-10">
      <img src="/rift-wars-logo-small.webp" alt="Rift Wars" class="h-8" style="filter: drop-shadow(0 0 8px rgba(242,173,35,0.3));" />
    </a>

    <!-- Desktop Nav — absolute center so it's page-centered regardless of logo/CTA widths -->
    <nav class="hidden lg:flex items-center gap-6 absolute left-1/2 -translate-x-1/2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          data-section={link.section}
          class:list={[
            'font-mono font-medium text-xs uppercase tracking-wider text-mm-text2 hover:text-mm-gold-primary transition-colors duration-200',
            link.section && 'nav-link',
          ]}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <!-- CTA + Hamburger -->
    <div class="flex items-center gap-4 z-10">
      <a href={gameUrl} target="_blank" rel="noopener" class="btn-primary text-xs py-2 px-5">
        Play Free
      </a>
      <button
        id="hamburger"
        class="lg:hidden flex flex-col gap-1.5 w-7 cursor-pointer bg-transparent border-none p-0"
        aria-label="Toggle menu"
      >
        <span class="block w-full h-0.5 bg-mm-text transition-all duration-300"></span>
        <span class="block w-full h-0.5 bg-mm-text transition-all duration-300"></span>
        <span class="block w-full h-0.5 bg-mm-text transition-all duration-300"></span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Menu — OUTSIDE header to avoid iOS backdrop-filter stacking context bug -->
<div id="mobile-menu" class="lg:hidden hidden fixed inset-0 top-16 z-[60]">
  <div class="absolute inset-0 bg-black"></div>
  <nav class="relative z-10 flex flex-col items-center justify-center gap-6 pt-16">
    {navLinks.map((link) => (
      <a
        href={link.href}
        class="mobile-link font-mono font-medium text-lg uppercase tracking-wider text-mm-text2 hover:text-mm-gold-primary transition-colors"
      >
        {link.label}
      </a>
    ))}
    <a href={gameUrl} target="_blank" rel="noopener" class="btn-filled btn-primary mt-4 text-sm">
      Play Free Now
    </a>
  </nav>
</div>

<style>
  header {
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(0, 0, 0, 0.8);
    border-bottom: 1px solid rgba(242, 173, 35, 0.08);
  }
  header.scrolled {
    background: rgba(0, 0, 0, 0.95);
    border-bottom-color: rgba(242, 173, 35, 0.15);
  }
  #hamburger.open span:nth-child(1) {
    transform: translateY(4px) rotate(45deg);
  }
  #hamburger.open span:nth-child(2) {
    opacity: 0;
  }
  #hamburger.open span:nth-child(3) {
    transform: translateY(-4px) rotate(-45deg);
  }
</style>

<script>
  // Scroll effect
  const nav = document.getElementById('site-nav')!;
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 50);
  });

  // Hamburger
  const hamburger = document.getElementById('hamburger')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  hamburger.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileMenu.classList.toggle('hidden');
    document.body.style.overflow = mobileMenu.classList.contains('hidden') ? '' : 'hidden';
  });

  // Close mobile menu on link click
  mobileMenu.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger.classList.remove('open');
      mobileMenu.classList.add('hidden');
      document.body.style.overflow = '';
    });
  });
</script>
