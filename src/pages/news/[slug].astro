---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articles, getArticleBySlug } from '../../lib/news';

export function getStaticPaths() {
  return articles.map(a => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = getArticleBySlug(slug!);

if (!article) {
  return Astro.redirect('/news');
}

const formattedDate = new Date(article.date).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<BaseLayout title={`${article.title} — Rift Wars`} description={article.summary}>
  <article class="section-padding pt-32 bg-mm-bg">
    <div class="section-container max-w-3xl">
      <!-- Back -->
      <a href="/news" class="font-rajdhani text-mm-cyan text-sm uppercase tracking-wider hover:text-mm-cyan-glow transition-colors mb-8 inline-block">
        &larr; Back to News
      </a>

      <!-- Hero Image -->
      <div class="relative h-64 sm:h-80 mb-8 overflow-hidden border border-mm-elevated/30">
        <img src={article.image} alt={article.title} class="w-full h-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-t from-mm-bg via-transparent to-transparent"></div>
      </div>

      <!-- Header -->
      <p class="font-rajdhani text-mm-cyan text-sm uppercase tracking-widest mb-3">{formattedDate}</p>
      <h1 class="font-orbitron text-2xl sm:text-3xl font-bold text-mm-text mb-8 neon-text tracking-wide leading-tight">
        {article.title}
      </h1>

      <!-- Content -->
      <div class="prose prose-invert max-w-none" set:html={article.content} />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose h2 {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.4rem;
    color: var(--accent-cyan);
    margin-top: 2rem;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }
  .prose h3 {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }
  .prose p {
    font-family: 'Exo 2', sans-serif;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .prose ul {
    list-style: none;
    padding: 0;
  }
  .prose li {
    font-family: 'Exo 2', sans-serif;
    color: var(--text-secondary);
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }
  .prose li::before {
    content: '\25C6';
    color: var(--accent-cyan);
    position: absolute;
    left: 0;
    font-size: 0.7rem;
    top: 0.3rem;
  }
  .prose strong {
    color: var(--text-primary);
  }
  .prose a {
    color: var(--accent-cyan);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  .prose a:hover {
    border-bottom-color: var(--accent-cyan);
  }
</style>
