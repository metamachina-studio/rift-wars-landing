---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { articles, getArticleBySlug } from '../../lib/news';

export function getStaticPaths() {
  return articles.map(a => ({ params: { slug: a.slug } }));
}

const { slug } = Astro.params;
const article = getArticleBySlug(slug!);

if (!article) {
  return Astro.redirect('/news');
}

const formattedDate = new Date(article.date + 'T12:00:00').toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});

// SEO description: prefer seoSummary; otherwise truncate summary to ≤155 chars on a word boundary.
function truncate(text: string, max = 155): string {
  if (text.length <= max) return text;
  const cut = text.slice(0, max);
  const lastSpace = cut.lastIndexOf(' ');
  return (lastSpace > 100 ? cut.slice(0, lastSpace) : cut).replace(/[.,;:\-—]+$/, '') + '…';
}
const seoDescription = article.seoSummary ?? truncate(article.summary);

const SITE = 'https://riftwars.metamachina.io';
const ogImageAbs = new URL(article.image, SITE).href;
const articleUrl = `${SITE}/news/${article.slug}/`;
const author = article.author ?? '1DigitalC';

// Determine "section" — Rift Wars Papers parts vs. patch notes vs. updates.
const isPaper = /the rift wars papers/i.test(article.summary) || /Part\s+(I{1,3}|IV|V|VI)/i.test(article.summary);
const isPatch = /^patch[ -]/i.test(article.title) || /patch notes/i.test(article.title);
const section = isPaper ? 'The Rift Wars Papers' : isPatch ? 'Patch Notes' : 'Updates';

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.title,
  description: seoDescription,
  image: [ogImageAbs],
  datePublished: article.date,
  dateModified: article.date,
  mainEntityOfPage: { '@type': 'WebPage', '@id': articleUrl },
  author: {
    '@type': 'Person',
    name: author,
    url: 'https://x.com/1DigitalC',
  },
  publisher: {
    '@type': 'Organization',
    name: 'Meta Machina',
    url: SITE,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE}/rift-wars-logo-large.webp`,
    },
  },
  articleSection: section,
};

const breadcrumbs = [
  { name: 'Home', item: `${SITE}/` },
  { name: 'News', item: `${SITE}/news/` },
  { name: article.title, item: articleUrl },
];
---

<BaseLayout
  title={`${article.title} — Rift Wars`}
  description={seoDescription}
  ogImage={article.image}
  ogImageAlt={article.title}
  ogType="article"
  twitterCreator="@1DigitalC"
  articleMeta={{
    publishedTime: article.date,
    author,
    authorUrl: 'https://x.com/1DigitalC',
    section,
  }}
  breadcrumbs={breadcrumbs}
  jsonLd={articleSchema}
>
  <article class="section-padding pt-32 bg-mm-bg">
    <div class="section-container max-w-3xl">
      <!-- Back -->
      <a href="/news" class="font-rajdhani text-mm-cyan text-sm uppercase tracking-wider hover:text-mm-cyan-glow transition-colors mb-8 inline-block">
        &larr; Back to News
      </a>

      <!-- Hero Image -->
      <div class="relative mb-8 overflow-hidden border border-mm-elevated/30 bg-mm-bg2">
        <img src={article.image} alt={article.title} class="w-full h-auto object-contain" />
      </div>

      <!-- Header -->
      <time datetime={article.date} class="block font-rajdhani text-mm-cyan text-sm uppercase tracking-widest mb-3">{formattedDate}</time>
      <h1 class="font-orbitron text-2xl sm:text-3xl font-bold text-mm-text mb-8 neon-text tracking-wide leading-tight">
        {article.title}
      </h1>

      <!-- Content -->
      <div class="prose prose-invert max-w-none" set:html={article.content} />
    </div>
  </article>
</BaseLayout>

<style is:global>
  .prose h2 {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.4rem;
    color: var(--accent-cyan);
    margin-top: 2rem;
    margin-bottom: 1rem;
    letter-spacing: 0.05em;
  }
  .prose h3 {
    font-family: 'Orbitron', sans-serif;
    font-size: 1.1rem;
    color: var(--text-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    letter-spacing: 0.05em;
  }
  .prose p {
    font-family: 'Exo 2', sans-serif;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1rem;
  }
  .prose ul {
    list-style: none;
    padding: 0;
  }
  .prose li {
    font-family: 'Exo 2', sans-serif;
    color: var(--text-secondary);
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }
  .prose li::before {
    content: '\25C6';
    color: var(--accent-cyan);
    position: absolute;
    left: 0;
    font-size: 0.7rem;
    top: 0.3rem;
  }
  .prose strong {
    color: var(--text-primary);
  }
  .prose a {
    color: var(--accent-cyan);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s;
  }
  .prose a:hover {
    border-bottom-color: var(--accent-cyan);
  }
</style>
